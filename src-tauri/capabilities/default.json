{
  "$schema": "../gen/schemas/desktop-schema.json",
  "capabilities": [
    {
      "identifier": "window-core",
      "description": "Scoped IPC for local app windows that need core invoke + window close/drag actions.",
      "windows": ["main", "onboarding", "popup", "settings", "edit_operations", "chat_*"],
      "permissions": [
        "core:default",
        "core:window:default",
        "core:window:allow-close",
        "core:window:allow-start-dragging"
      ]
    },
    {
      "identifier": "onboarding-opener",
      "description": "Allows opening external links from onboarding, settings, and chat windows.",
      "windows": ["onboarding", "settings", "chat_*"],
      "permissions": ["opener:default"]
    }
  ]
}
