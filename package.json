{
  "name": "ai-texttool",
  "private": true,
  "version": "1.1.1",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "tauri build",
    "build:web": "vue-tsc --noEmit && vite build",
    "lint": "npm run lint:vue && npm run lint:rust",
    "lint:vue": "eslint src --ext .vue,.js,.ts",
    "lint:rust": "cd src-tauri && cargo clippy -- -D warnings",
    "fix": "npm run fix:vue && npm run fix:rust",
    "fix:vue": "eslint src --ext .vue,.js,.ts --fix && prettier --write \"src/**/*.{vue,js,ts,html,css,json}\"",
    "fix:rust": "cd src-tauri && cargo fmt",
    "check": "npm run lint && prettier --check \"src/**/*.{vue,js,ts,html,css,json}\"",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "security-check": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@lucide/vue": "^1.22.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@types/dompurify": "^3.2.0",
    "@types/marked": "^5.0.2",
    "dompurify": "^3.4.11",
    "marked": "^18.0.5",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.10.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.8.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2",
    "vue-tsc": "^3.2.6"
  }
}
